<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Distribution method: app-store targets both TestFlight and App Store -->
    <key>method</key>
    <string>app-store</string>

    <key>teamID</key>
    <string>3AKEMCF7CZ</string>

    <!-- Upload dSYM symbol files for crash reporting in Xcode Organizer -->
    <key>uploadSymbols</key>
    <true/>

    <!-- App Store Connect handles per-device thinning; export a universal IPA -->
    <key>thinning</key>
    <string>&lt;none&gt;</string>

    <!-- Manual signing: CI injects the actual UUID at runtime via PlistBuddy -->
    <key>signingStyle</key>
    <string>manual</string>

    <key>signingCertificate</key>
    <string>Apple Distribution</string>

    <!-- The workflow replaces this placeholder with the real profile UUID before export -->
    <key>provisioningProfiles</key>
    <dict>
        <key>com.mobile.MarkIT</key>
        <string>PROFILE_UUID_PLACEHOLDER</string>
    </dict>

    <!-- Export to disk; the workflow uploads via xcrun altool separately -->
    <key>destination</key>
    <string>export</string>
</dict>
</plist>
